{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "my-claude-terminal",
  "version": "0.1.0",
  "identifier": "com.devljm.claude-terminal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "My Claude Terminal",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "resources": {
      "../sidecar/dist/index.js": "sidecar/index.js",
      "../sidecar/node_modules": "sidecar/node_modules",
      "../sidecar/package.json": "sidecar/package.json"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY1RTBCNTIyRjA2NEYwQTQKUldTazhHVHdJclhnWlFGRHZWaVBDUjhFVld1Rkc5S1JrMDJsaDNQUlhqSUtzeGFtQ3NkNDhFOUcK",
      "endpoints": [
        "https://github.com/lee-jongmyoung/my-claude-terminal/releases/latest/download/latest.json"
      ]
    }
  }
}
