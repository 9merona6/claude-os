{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "Claude OS",
    "version":  "0.1.6",
    "identifier":  "com.devljm.claude-terminal",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "devUrl":  "http://127.0.0.1:1420",
                  "beforeBuildCommand":  "npm run build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "Claude OS",
                                    "width":  1280,
                                    "height":  800,
                                    "minWidth":  900,
                                    "minHeight":  600,
                                    "decorations":  true,
                                    "transparent":  false
                                }
                            ],
                "security":  {
                                 "csp":  "default-src \u0027self\u0027; connect-src \u0027self\u0027 ipc: http://ipc.localhost ws://127.0.0.1:7891; img-src \u0027self\u0027 data: asset: http://asset.localhost; style-src \u0027self\u0027 \u0027unsafe-inline\u0027; font-src \u0027self\u0027 data:; script-src \u0027self\u0027"
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ],
                   "createUpdaterArtifacts":  true,
                   "resources":  {
                                     "../sidecar/dist/index.js":  "sidecar/index.js",
                                     "../sidecar/node_modules":  "sidecar/node_modules",
                                     "../sidecar/package.json":  "sidecar/package.json"
                                 }
               },
    "plugins":  {
                    "updater":  {
                                    "pubkey":  "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY1RTBCNTIyRjA2NEYwQTQKUldTazhHVHdJclhnWlFGRHZWaVBDUjhFVld1Rkc5S1JrMDJsaDNQUlhqSUtzeGFtQ3NkNDhFOUcK",
                                    "endpoints":  [
                                                      "https://github.com/9merona6/claude-os/releases/latest/download/latest.json"
                                                  ],
                                    "windows":  {
                                                    "installMode":  "quiet"
                                                }
                                }
                }
}
